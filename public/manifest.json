{
  "name": "NovaJX Mining",
  "short_name": "NovaJX",
  "description": "NovaJX is the next-gen mobile crypto. Mine NJX coins daily, invite friends, and earn referral rewards.",
  "start_url": "/",
  "id": "/",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "orientation": "portrait",
  "background_color": "#16110a",
  "theme_color": "#f5b800",
  "categories": ["finance", "productivity", "business"],
  "prefer_related_applications": false,
  "launch_handler": { "client_mode": "navigate-existing" },
  "edge_side_panel": { "preferred_width": 480 },
  "handle_links": "preferred",
  "scope_extensions": [{ "origin": "https://app.novajx.com" }],
  "screenshots": [
    {
      "src": "/screenshots/mobile.png",
      "sizes": "512x1024",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "NovaJX Mining dashboard on mobile"
    },
    {
      "src": "/screenshots/desktop.png",
      "sizes": "1280x800",
      "type": "image/png",
      "form_factor": "wide",
      "label": "NovaJX Mining dashboard on desktop"
    }
  ],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Open your mining dashboard",
      "url": "/dashboard",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Wallet",
      "short_name": "Wallet",
      "description": "View your NJX wallet",
      "url": "/wallet",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Referrals",
      "short_name": "Referrals",
      "description": "Invite friends and earn rewards",
      "url": "/referrals",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "icons": [
    { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ]
}
